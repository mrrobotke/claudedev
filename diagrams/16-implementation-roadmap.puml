@startgantt
skinparam dpi 150
skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 12

<style>
ganttDiagram {
  task {
    BackgroundColor #1A5276
    LineColor #2980B9
    FontColor #FFFFFF
    FontSize 11
  }
  milestone {
    BackgroundColor #E74C3C
    LineColor #C0392B
    FontColor #FFFFFF
  }
  separator {
    BackgroundColor #2C3E50
    LineColor #7F8C8D
    FontColor #FFFFFF
    FontSize 12
    FontStyle bold
  }
}
</style>

Project starts 2025-01-06
printscale weekly

title NEXUS Brain — Implementation Roadmap (12 Weeks)

